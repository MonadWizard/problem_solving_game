# Copy to .env.local for local dev. Leave unset for guest-only mode (always works).
# See supabase/SETUP.md for how to obtain these.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: only enables LeetCode submission verification if set (see worker/README.md).
VITE_VERIFY_WORKER_URL=

# Optional: override the Vite base path (default /grand-algorithm/). Set to / for
# a custom domain or user page. See .claude/skills/deploy/SKILL.md.
VITE_BASE=
